From 0a8dfb20d4ef45f33f8d9eef31c6a3fba309479a Mon Sep 17 00:00:00 2001
From: Simon Bruder <simon@sbruder.de>
Date: Tue, 7 Jul 2026 23:26:45 +0200
Subject: [PATCH 2/3] Allow passing IMAP password as file

This is useful when the configuration file is publicly readable.
---
 network-journal.reference.yml |  2 ++
 src/config.rs                 | 20 ++++++++++++++++++--
 src/main.rs                   |  2 +-
 3 files changed, 21 insertions(+), 3 deletions(-)

diff --git a/network-journal.reference.yml b/network-journal.reference.yml
index 72007bb..d28ccc7 100644
--- a/network-journal.reference.yml
+++ b/network-journal.reference.yml
@@ -17,6 +17,8 @@ imap:
   port: 993
   username: ''
   password: ''
+  # takes precedence when specified
+  #password_file: '/path/to/imap-password-file'
 
 filter:
   # domain names e.g. first.example.org to exclude third party domains (SPAM)
diff --git a/src/config.rs b/src/config.rs
index 153b9c6..f78642a 100644
--- a/src/config.rs
+++ b/src/config.rs
@@ -19,6 +19,7 @@
 use std::path::PathBuf;
 
 use config::Config;
+use log::error;
 use serde::{Deserialize, Serialize};
 
 #[derive(Serialize, Deserialize, Clone, Debug)]
@@ -94,7 +95,9 @@ pub struct ImapConfig {
     /// IMAP username
     pub username: String,
     /// IMAP password
-    pub password: String,
+    password: String,
+    /// IMAP password file, takes precedence when [`Some`]
+    password_file: Option<PathBuf>,
 }
 
 impl Default for ImapConfig {
@@ -104,11 +107,24 @@ impl Default for ImapConfig {
             host: "127.0.0.1".to_string(),
             port: 993,
             username: "".to_string(),
-            password: "".to_string()
+            password: "".to_string(),
+            password_file: None,
         }
     }
 }
 
+impl ImapConfig {
+    pub fn password(&self) -> String {
+        self.password_file
+            .as_ref()
+            .map(std::fs::read_to_string)
+            .and_then(|res| res
+                .inspect_err(|err| error!("could not read IMAP password file: {err}"))
+                .ok())
+            .unwrap_or(self.password.clone())
+    }
+}
+
 #[derive(Serialize, Deserialize, Clone, Debug)]
 pub struct FilterConfig {
     /// empty list allows all domains
diff --git a/src/main.rs b/src/main.rs
index ee81b87..7fec7e3 100644
--- a/src/main.rs
+++ b/src/main.rs
@@ -113,7 +113,7 @@ async fn main() -> std::io::Result<()> {
                     &cfg.imap.host,
                     cfg.imap.port,
                     &cfg.imap.username,
-                    &cfg.imap.password
+                    &cfg.imap.password()
                 );
 
                 match imap_connect_res {
